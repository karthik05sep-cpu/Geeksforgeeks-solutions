class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int f =Integer.MIN_VALUE;
        int s=Integer.MIN_VALUE;
        for(int i=0;i<arr.length;i++){
            if(f<arr[i]){
                
                s=f;
                f=arr[i];
            }
            if(s<arr[i]&&arr[i]<f){
                s=arr[i];
            }
        }
        return s==Integer.MIN_VALUE?-1:s;
    }
}
